---
interface Props {
  greeting?: string;
  intro?: string;
}

const {
  greeting = 'Hello!',
  intro = 'This website is dedicated to my work and personal projects. You can find some of them below, along with brief descriptions and ideas behind them. Everything else is available in my GitHub (link above).'
} = Astro.props;
---

<section class="hero animate-on-scroll">
  <h1 class="hero-title">{greeting}</h1>
  <p class="hero-intro">{intro}</p>
</section>

<style>
  .hero {
    text-align: center;
    margin-bottom: var(--spacing-lg);
  }

  .hero-title {
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-text);
    animation: slideUp 0.6s ease-out;
  }

  .hero-intro {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
    animation: slideUp 0.6s ease-out 0.1s both;
  }
</style>
